# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # clave pública (sólo lectura por RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # clave secreta de servidor (NO exponer)

# Admin (tú)
ADMIN_PASSWORD=cambia-esta-contrasena
